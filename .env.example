# Copia este archivo a .env.local y rellena los valores.
# En producción (Vercel), configura las mismas variables en el proyecto.

# --- Firebase (proyecto: servipartz-f01a6) — opcional
# https://console.firebase.google.com/project/servipartz-f01a6/settings/general
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Email: Gmail o Resend — obligatorio para cotización y agendar cita
# En Vercel: Project → Settings → Environment Variables (añade las que uses)

# Gmail: 1) Activa verificación en 2 pasos en tu cuenta Google
#        2) Crea "Contraseña de aplicación" en https://myaccount.google.com/apppasswords
#        3) Pega aquí el correo y la contraseña de 16 caracteres
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Resend (alternativa): https://resend.com → API Keys. Para enviar a cualquier correo, verifica tu dominio en Resend y define:
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=Servipartz

# --- OpenAI (opcional): chatbot con IA
OPENAI_API_KEY=
